generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
// Catalog
// ────────────────────────────────────────────────────────────────────────────

model Item {
  id             Int       @id @default(autoincrement())
  marketHashName String    @unique
  name           String
  iconUrl        String?
  type           String?
  tags           Json?
  nameId         String?
  firstSeenAt    DateTime  @default(now())
  lastScrapedAt  DateTime?

  snapshots PriceSnapshot[]
  history   PriceHistory[]
  orderbook OrderBook[]
  positions Position[]
  alerts    Alert[]
  watchlist Watchlist[]
  sboxStats SboxGameStat[]
  nameIdResolvedAt DateTime?

  @@index([type])
}

// Intraday snapshots — append-only, aggressively pruned.
model PriceSnapshot {
  id           BigInt   @id @default(autoincrement())
  itemId       Int
  ts           DateTime @default(now())
  lowestPrice  Decimal? @db.Decimal(12, 4)
  medianPrice  Decimal? @db.Decimal(12, 4)
  volume24h    Int?
  sellListings Int?

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, ts])
  @@index([ts])
}

// Daily OHLC-ish rows from Steam pricehistory.
model PriceHistory {
  id     BigInt   @id @default(autoincrement())
  itemId Int
  day    DateTime @db.Date
  price  Decimal  @db.Decimal(12, 4)
  volume Int

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, day])
  @@index([day])
}

// Order book snapshots from itemordershistogram (works anonymously).
// Walls stored as compact JSON: [[price, qty], ...] capped at top 20 levels.
model OrderBook {
  id             BigInt   @id @default(autoincrement())
  itemId         Int
  ts             DateTime @default(now())
  buyTop         Decimal? @db.Decimal(12, 4)
  sellTop        Decimal? @db.Decimal(12, 4)
  spreadPct      Decimal? @db.Decimal(8, 4)
  buyTotalUsd    Decimal? @db.Decimal(14, 2)
  sellTotalUsd   Decimal? @db.Decimal(14, 2)
  liquidityScore Decimal? @db.Decimal(14, 2)
  buyWalls       Json?
  sellWalls      Json?

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, ts])
}

// ────────────────────────────────────────────────────────────────────────────
// Portfolio
// ────────────────────────────────────────────────────────────────────────────

model Position {
  id                Int       @id @default(autoincrement())
  userId            String?   // Telegram user ID (null = web/legacy)
  itemId            Int
  qty               Int
  buyPrice          Decimal   @db.Decimal(12, 4) // always USD
  buyPriceOriginal  Decimal?  @db.Decimal(14, 4)
  buyCurrency       String    @default("USD")
  buyDate           DateTime
  sellPrice         Decimal?  @db.Decimal(12, 4)
  sellDate          DateTime?
  note              String?

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([userId])
}

model Alert {
  id        Int      @id @default(autoincrement())
  userId    String?  // Telegram user ID
  itemId    Int
  // "above" | "below" | "change_pct" | "sales_spike" | "snipe"
  type      String
  threshold Decimal  @db.Decimal(12, 4)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  firedAt   DateTime?
  firedPrice Decimal? @db.Decimal(12, 4)
  fireCount Int      @default(0)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    String?  // Telegram user ID
  itemId    Int
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

// Telegram bot feedback (Lab 3 requirement: collect from 3+ users).
// User preference: which currency to display. Single-row table.
model Settings {
  id       Int    @id @default(1)
  currency String @default("USD") // "USD" | "KZT"
}

model Feedback {
  id        Int      @id @default(autoincrement())
  userId    String   // Telegram user ID
  username  String?  // Telegram @username
  rating    Int      // 1-5
  text      String?  // optional free-text
  createdAt DateTime @default(now())
}

// Stats pulled from sbox.game/metrics/skins via headless browser.
// Per-item × per-timeframe. This is where the real stock / supply data
// lives — Facepunch publishes total revenue + units traded.
// timeframe values: "all" | "30d" | "7d" | "1d"
model SboxGameStat {
  id         Int      @id @default(autoincrement())
  itemId     Int
  timeframe  String
  usdRevenue Decimal  @db.Decimal(14, 2)
  units      Int
  scrapedAt  DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, timeframe])
  @@index([scrapedAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Infra
// ────────────────────────────────────────────────────────────────────────────

model FxRate {
  code String   @id // e.g. "KZT"
  rate Decimal  @db.Decimal(18, 8) // units per 1 USD
  ts   DateTime @default(now())
}

model ScrapeRun {
  id             Int       @id @default(autoincrement())
  kind           String
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  ok             Boolean?
  error          String?
  itemsProcessed Int       @default(0)
}
