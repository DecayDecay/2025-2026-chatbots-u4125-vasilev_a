# Postgres
POSTGRES_USER=sbox
POSTGRES_PASSWORD=sbox
POSTGRES_DB=sbox
DATABASE_URL=postgresql://sbox:sbox@localhost:5432/sbox?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Steam
STEAM_APPID=590830
# Currency code for Steam API (1 = USD)
STEAM_CURRENCY=1
# OPTIONAL: cookie from a logged-in Steam session.
# Only used for the one-shot pricehistory backfill (year of daily candles).
# Anonymous mode does NOT need this — it builds history from snapshots.
STEAM_LOGIN_SECURE=

# Telegram bot (from @BotFather)
BOT_TOKEN=

# Scraper tuning — Steam market hard-blocks bursts above ~9 req in 10s.
# 12 req/min = 5s spacing, comfortably below the limit.
SCRAPER_REQ_PER_MIN=12
SCRAPER_CONCURRENCY=1

# Logging
LOG_LEVEL=info
NODE_ENV=production
